generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String          @id @default(cuid())
  email       String          @unique
  name        String
  role        String          @default("user")
  lastLoginAt DateTime?
  reports     DailyReport[]
  auditLogs   AdminAuditLog[]
}

model DailyReport {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  reportDate     DateTime @db.Date
  sleep          Int
  body           Int
  mood           Int
  fog            Int
  energy         Int
  connection     Int
  wednesdayExtra Int?
  otherNote      String?
  createdAt      DateTime @default(now())

  @@unique([userId, reportDate])
}

model PositiveMessage {
  id      String @id @default(cuid())
  content String
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  actor       User     @relation(fields: [actorUserId], references: [id])
  action      String
  targetType  String
  targetId    String
  summary     String
  createdAt   DateTime @default(now())
}
