# コピーして .env.local（ローカル）または Vercel の Environment Variables に設定してください。
# 実際の値はリポジトリにコミットしないでください。

# --- アプリ（Prisma / API）---
# 本番: Supabase → Project Settings → Database → Connection string
# マイグレーション初回は Direct (5432) 推奨。運用中は Pooler (6543) も可（README 参照）
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# 任意: migrate deploy 専用の直結 URL（設定時は prisma CLI がこちらを優先）
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# --- Supabase Auth（ブラウザ公開可）---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY"
